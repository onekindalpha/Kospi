//@version=6
indicator("NYSE/NASDAQ 고점저점수치 (NH-NL)", overlay=false)

market  = input.string("NYSE", "마켓", options=["NYSE", "NASDAQ"])
showCum = input.bool(false, "누적값 보기")
maLen   = input.int(10, "MA Length", minval=1)

newHighs = market == "NYSE" ? request.security("INDEX:HIGN", timeframe.period, close) : request.security("INDEX:HIGQ", timeframe.period, close)
newLows  = market == "NYSE" ? request.security("INDEX:LOWN", timeframe.period, close) : request.security("INDEX:LOWQ", timeframe.period, close)

nhnl    = newHighs - newLows
nhnlCum = ta.cum(nhnl)
nhnlMA  = ta.sma(nhnl, maLen)

barColor = nhnl >= 0 ? color.new(color.teal, 30) : color.new(color.red, 30)
plot(showCum ? nhnlCum : nhnl, title="NH-NL", style=showCum ? plot.style_line : plot.style_histogram, color=showCum ? color.new(color.blue, 0) : barColor, linewidth=showCum ? 2 : 1)
plot(showCum ? na : nhnlMA, title="NH-NL MA", color=color.new(color.orange, 0), linewidth=1)

// 0선 추가
hline(0, "기준선(0)", color=color.new(color.white, 40), linestyle=hline.style_solid, linewidth=1)

isBull = nhnl > 0 and nhnlMA > 0
isBear = nhnl < 0 and nhnlMA < 0
bgcolor(isBull ? color.new(color.teal, 93) : isBear ? color.new(color.red, 93) : na)

string judgement = ""
color jColor = color.gray
if nhnl > 200 and nhnlMA > 0
    judgement := "강한 상승 브레드스"
    jColor := color.teal
else if nhnl > 0 and nhnlMA > 0
    judgement := "양호"
    jColor := color.teal
else if nhnl < -200 and nhnlMA < 0
    judgement := "강한 하락 브레드스"
    jColor := color.red
else if nhnl < 0 and nhnlMA < 0
    judgement := "주의"
    jColor := color.red
else
    judgement := "혼조"
    jColor := color.gray

var table t = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "지표",     text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(t, 1, 0, "값",       text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(t, 0, 1, "NH-NL",    text_color=color.white)
    table.cell(t, 1, 1, str.tostring(nhnl,   format.mintick), text_color=color.white)
    table.cell(t, 0, 2, "NH-NL MA", text_color=color.white)
    table.cell(t, 1, 2, str.tostring(nhnlMA, format.mintick), text_color=color.white)
    table.cell(t, 0, 3, "MA Length",text_color=color.white)
    table.cell(t, 1, 3, str.tostring(maLen),  text_color=color.white)
    table.cell(t, 0, 4, "마켓",     text_color=color.white)
    table.cell(t, 1, 4, market,     text_color=color.white)
    table.cell(t, 0, 5, "판정",     text_color=color.white)
    table.cell(t, 1, 5, judgement,  text_color=jColor)